{
  "rewrites": [
    { "source": "/for-agencies", "destination": "/for-agencies.html" },
    { "source": "/for-agencies/", "destination": "/for-agencies.html" },
    { "source": "/agencies", "destination": "/agencies.html" },
    { "source": "/agencies/", "destination": "/agencies.html" },
    { "source": "/agencies/:country", "destination": "/agencies.html" },
    { "source": "/agencies/:country/", "destination": "/agencies.html" },
    { "source": "/agencies/:country/:city", "destination": "/agencies.html" },
    { "source": "/agencies/:country/:city/", "destination": "/agencies.html" },
    { "source": "/agency/:slug", "destination": "/agencies.html" },
    { "source": "/agency/:slug/", "destination": "/agencies.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/blog/", "destination": "/blog.html" },
    { "source": "/blog/:slug", "destination": "/blog/:slug.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/about/", "destination": "/about.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/contact/", "destination": "/contact.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/privacy/", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/terms/", "destination": "/terms.html" },
    { "source": "/saved", "destination": "/saved.html" },
    { "source": "/saved/", "destination": "/saved.html" },
    { "source": "/tools/rental-cost-calculator", "destination": "/tools/rental-cost-calculator.html" },
    { "source": "/tools/rental-cost-calculator/", "destination": "/tools/rental-cost-calculator.html" },
    { "source": "/tools/deposit-law-comparison", "destination": "/tools/deposit-law-comparison.html" },
    { "source": "/tools/deposit-law-comparison/", "destination": "/tools/deposit-law-comparison.html" },
    { "source": "/tools/agency-scoring-methodology", "destination": "/tools/agency-scoring-methodology.html" },
    { "source": "/tools/agency-scoring-methodology/", "destination": "/tools/agency-scoring-methodology.html" },
    { "source": "/tools", "destination": "/tools/index.html" },
    { "source": "/tools/", "destination": "/tools/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/(.*)\\.(html)",
      "headers": [
        { "key": "Cache-Control", "value": "public, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=60, s-maxage=300, must-revalidate" }
      ]
    }
  ]
}
